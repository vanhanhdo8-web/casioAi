# ===== GOOGLE GEMINI API =====
# Lấy API key miễn phí tại: https://aistudio.google.com/apikey
# Đăng nhập bằng Google account, tạo API key mới và paste vào đây
GEMINI_API_KEY=your-actual-gemini-api-key-here

# ===== FLASK SECURITY =====
# Secret key cho session - nên là chuỗi ngẫu nhiên, dài và khó đoán
# Có thể tạo bằng: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production

# ===== SERVER CONFIGURATION =====
# Cổng chạy server (mặc định 7860 cho Hugging Face Spaces)
PORT=7860

# ===== ENVIRONMENT =====
# Môi trường: development, production, testing
FLASK_ENV=development

# Debug mode: 1 = bật, 0 = tắt
FLASK_DEBUG=1

# ===== CACHE CONFIGURATION =====
# Thời gian cache (giây)
CACHE_TIMEOUT=300

# ===== RATE LIMITING =====
# Giới hạn requests cho Gemini API (miễn phí: 60 requests/phút)
GEMINI_RATE_LIMIT=60

# ===== UPLOAD CONFIGURATION =====
# Kích thước file tối đa (bytes) - mặc định 16MB
MAX_CONTENT_LENGTH=16777216

# ===== LOGGING =====
# Mức độ log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== TIMEZONE =====
# Múi giờ mặc định
TIMEZONE=Asia/Ho_Chi_Minh
